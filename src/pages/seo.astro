---
import Layout from "../layouts/Layout.astro";
import HeroSecondary from "../components/HeroSecondary.astro";
import Section from "../components/ui/Section.astro";
import CTAAboveFooter from "../components/CTAAboveFooter.astro";

const pageTitle = "SEO";
const metaDescription = "Improve your visibility online with SEO services from Dockside Web Solutions. We build fast, search-friendly websites and optimize your online presence to help local businesses rank higher and attract more customers.";
---

<Layout title={pageTitle} description={metaDescription}>
    <HeroSecondary
        label="SEO"
        heading="Search Engine Optimization"
        description="Learn how Dockside Web Solutions helps businesses grow through smart SEO strategies, fast website performance, local search optimization, and search-friendly design built to increase visibility and generate leads."
    />

    <Section bg="light">
        <div class="mx-auto max-w-3xl rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm">
            <p class="text-sm font-semibold tracking-[0.2em] text-primary uppercase mb-3">
            Work In Progress
            </p>

            <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-4">
            This Page Is Currently Being Built
            </h2>

            <p class="text-slate-600 leading-relaxed max-w-2xl mx-auto">
            We’re currently putting the finishing touches on this page. Check back soon
            for more details about our services, pricing, and how we can help your
            business grow online.
            </p>
        </div>
    </Section>

    
    <CTAAboveFooter />
</Layout>