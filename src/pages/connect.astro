---
import Section from "../components/ui/Section.astro";
import SectionLabel from "../components/ui/SectionLabel.astro";
import Heading from "../components/ui/Heading.astro";
import Layout from "../layouts/Layout.astro";
import Button from "../components/ui/Button.astro";
import Text from "../components/ui/Text.astro";
import CTAAboveFooter from "../components/CTAAboveFooter.astro";
import TestimonialCards from "../components/TestimonialCards.astro";
import OurWork from "../components/OurWork.astro";
import heroImage from "../assets/heroImage.png";
import { CheckCircle, Anchor } from "lucide-astro";
import FAQ from "../components/FAQ.astro";

const pageTitle = "Connect";
const metaDescription = "Welcome to Dockside Web Solutions. View our portfolio, check out our testimonials, and find all our professional links in one place. Let's build something.";
---

<Layout title={pageTitle} description={metaDescription}>

  <!-- HERO SECTION -->
  <section
  class="hero-section relative bg-navy min-h-[75vh] flex items-center overflow-hidden pb-24 bg-cover bg-no-repeat bg-scroll lg:bg-fixed hero-parallax"
  style={`background-image: url(${heroImage.src}); background-position: right center;`}
>
  <!-- Left-fade gradient overlay — keeps dock visible on the right -->
  <div class="absolute inset-0 bg-linear-to-r from-navy via-navy/90 to-navy/25"></div>
  <div class="absolute inset-0 bg-black/20"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10 pt-20 w-full">
    <div class="max-w-175 animate-fade-in-up">

      <!-- Eyebrow -->
      <div class="flex items-center justify-center sm:justify-start gap-2 mb-6">
        <div class="h-px w-13 bg-gold"></div>
        <span class="text-gold font-medium uppercase tracking-widest text-xs" aria-hidden="true"><Anchor/></span>
        <div class="h-px w-13 bg-gold"></div>
      </div>

      <h1 class="font-heading font-bold text-white leading-[1.05] mb-4 tracking-tight text-4xl sm:text-5xl md:text-6xl lg:text-[4rem] text-center sm:text-left">
        <span class="text-gold">Custom Websites</span> Built
        for <span class="text-gold">Small Businesses</span>
      </h1>

      <p class="text-base sm:text-lg text-white mb-8 max-w-xl text-center sm:text-left mx-auto sm:mx-0">
        We build high-performing websites that look professional, load quickly,
        rank better on Google, and help turn clicks into paying customers.
      </p>

      <!-- CTAs — side by side even on mobile, full row -->
      <div class="flex flex-row gap-3 mb-8 items-center justify-center sm:justify-start">
        <a href="/">
          <Button variant="primary" size="lg" class="w-full sm:w-auto">
            View Homepage
          </Button>
        </a>
        <a href="/pricing/">
          <Button variant="outline" size="lg" class="w-full sm:w-auto text-white border-white/60">
            See Pricing
          </Button>
        </a>
      </div>

      <!-- Trust signals -->
      <div class="flex flex-col items-center sm:items-start sm:flex-row flex-wrap gap-2 sm:gap-8 text-white/75">
        <div class="flex items-center gap-2 animate-fade-in-up [animation-delay:0.5s] opacity-0 [animation-fill-mode:forwards]">
          <CheckCircle class="w-4 h-4 text-gold shrink-0" />
          <span class="text-sm">Live in 2-3 weeks</span>
        </div>
        <div class="flex items-center gap-2 animate-fade-in-up [animation-delay:0.6s] opacity-0 [animation-fill-mode:forwards]">
          <CheckCircle class="w-4 h-4 text-gold shrink-0" />
          <span class="text-sm">Unlimited Updates</span>
        </div>
        <div class="flex items-center gap-2 animate-fade-in-up [animation-delay:0.7s] opacity-0 [animation-fill-mode:forwards]">
          <CheckCircle class="w-4 h-4 text-gold shrink-0" />
          <span class="text-sm">Mobile Responsive</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave Divider -->
  <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-0">
    <svg class="relative block w-full h-24" viewBox="0 0 1440 320" preserveAspectRatio="none">
      <path
        fill="#F8FAFC"
        d="M0,160L48,176C96,192,192,224,288,213.3C384,203,480,149,576,149.3C672,149,768,203,864,218.7C960,235,1056,213,1152,186.7C1248,160,1344,128,1392,112L1440,96L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"
      />
    </svg>
  </div>
</section>

  <Section id="portfolio" class="pb-0!">
    <div class="sticky top-[15vh] z-0 min-h-[30vh] flex items-center justify-center px-6 pb-20">
        <div class="text-center max-w-3xl mx-auto">
          <SectionLabel>Our Portfolio</SectionLabel>
          <Heading>Teams We've Worked With</Heading>
          <div class="mb-6">
            <Text>Check out some of our latest projects and see how we can help your business grow.</Text>
          </div>
          <div class="flex flex-wrap justify-center gap-4">
            <a href="/contact/">
              <Button variant="primary">Start Your Project</Button>
            </a>
            <a href="/pricing/">
              <Button variant="navyOutline">See Pricing</Button>
            </a>
          </div>
        </div>
      </div>
    <OurWork />
  </Section>

  <Section bg="white" id="reviews">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <SectionLabel>
        Real Growth, Real Results
      </SectionLabel>
      <Heading>
        Client Testimonials
      </Heading>
    </div>

    <TestimonialCards />

    <div  class="text-center max-w-3xl mx-auto pt-15">
      <a href="/reviews/">
        <Button>
          See More Reviews
        </Button>
      </a>
    </div>
  </Section>

  <Section id="faq" class="scroll-mt-24">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <SectionLabel>
        Common Questions
      </SectionLabel>
      <Heading>
        Frequently Asked Questions
      </Heading>
      <p class="pt-3">
        We know starting a new website project can raise a few questions. Here are some quick answers to help you feel confident moving forward.
      </p>
    </div>

    <FAQ />

    <div  class="text-center max-w-3xl mx-auto pt-15">
      <a href="/faq/">
        <Button>
          See More FAQs
        </Button>
      </a>
    </div>
   
  </Section>

  <CTAAboveFooter />
</Layout>