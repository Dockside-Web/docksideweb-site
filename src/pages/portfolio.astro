---
import Layout from "../layouts/Layout.astro";
import HeroSecondary from "../components/HeroSecondary.astro";
import Section from "../components/ui/Section.astro";
import Heading from "../components/ui/Heading.astro";
import Button from "../components/ui/Button.astro";
import CTAAboveFooter from "../components/CTAAboveFooter.astro";
import PortfolioComponent from "../components/Portfolio.astro";

const pageTitle = "Portfolio";
const metaDescription =
  "Browse our portfolio of custom websites for small businesses. See modern designs built for leads, speed, and growth.";
---

<Layout title={pageTitle} description={metaDescription}>
  <HeroSecondary
    label="Businesses We've Worked With"
    heading="Portfolio"
    description="Check out some of our latest projects and see how we can help your business grow."
  />

  <Section bg="light">
    <PortfolioComponent show="featured" />

    <div class="flex flex-wrap justify-center gap-4">
      <a href="/contact/">
        <Button variant="primary">Start Your Project</Button>
      </a>
      <a href="/pricing/">
        <Button variant="navyOutline">See Pricing</Button>
      </a>
    </div>
  </Section>

  <Section bg="navy">
    <div class="text-center max-w-3xl mx-auto pb-12">
      <Heading class="text-white">All Projects</Heading>
    </div>

    <PortfolioComponent show="grid" />
  </Section>

  <CTAAboveFooter />
</Layout>
