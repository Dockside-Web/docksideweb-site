---
import { Image } from "astro:assets";
import CTABackgroundImage from "../assets/CTABackgroundImage.webp";
import Layout from "../layouts/Layout.astro";
import HeroSecondary from "../components/HeroSecondary.astro";
import Section from "../components/ui/Section.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import SectionLabel from "../components/ui/SectionLabel.astro";
import Button from "../components/ui/Button.astro";
import CTAAboveFooter from "../components/CTAAboveFooter.astro";
import Reviews from "../components/Reviews.astro";

const pageTitle = "About Us";
const metaDescription =
  "Learn about Dockside Web Solutions, a website development studio creating custom, high-performing static websites with hosting services, modern design, and dependable support for small businesses.";
---

<Layout title={pageTitle} description={metaDescription}>
  <HeroSecondary
    label="About Us"
    heading="About Dockside Web Solutions"
    description="Learn who we are, what we value, and how Dockside Web Solutions builds custom websites that help small businesses grow with modern design, reliable support, and a straightforward process."
  />

  <Section>
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-[0.85fr_1.15fr] items-center">
        <div class="relative">
          <div
            class="overflow-hidden rounded-2xl shadow-2xl border-4 border-white"
          >
            <Image
              src={CTABackgroundImage}
              alt="Photo of Riley Caldwell, the founder and developer of Dockside Web Solutions"
              class="w-full object-cover aspect-4/5 bg-navy/10"
            />
          </div>

          <div
            class="absolute -bottom-6 -right-6 md:right-4 bg-navy text-white p-5 rounded-xl shadow-xl min-w-55"
          >
            <div class="flex items-center gap-4">
              <div>
                <div class="text-lg font-bold leading-tight">
                  Riley Caldwell
                </div>
                <div
                  class="text-xs uppercase tracking-widest text-teal font-semibold"
                >
                  Founder and Developer
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="flex flex-col">
          <SectionLabel>About Us</SectionLabel>
          <Heading>
            The Developer Behind<br />
            <span class="italic text-teal text-pretty">
              Dockside Web Solutions</span
            >
          </Heading>
          <div class="mt-8 space-y-5">
            <Text>
              I’m Riley Caldwell, the owner and lead developer behind Dockside
              Web Solutions. I studied Computer Science at UNC Wilmington and
              work as a software engineer while starting Dockside Web Solutions
              in 2025. The goal was simple: build websites for small businesses
              that actually feel fast, modern, and intentional, not like
              something pieced together from a template.
            </Text>

            <Text>
              The choice shouldn't have to be between a $5,000 upfront
              investment or a generic, clunky "DIY" template that stalls growth.
              Every project at Dockside Web Solutions is custom-coded from the
              ground up to eliminate WordPress bloat and recycled themes. This
              focus on speed, security, and clean code ensures your website
              functions as a high-performance, 24/7 sales tool.
            </Text>

            <Text>
              High-quality web design works best when it's accessible.
              Professional, custom builds start at <strong
                >$0 down and $79 a month</strong
              > to keep your cash flow steady. With hosting, security, and ongoing
              updates completely handled, you stay focused on running your business
              while the technical heavy lifting is taken care of.
            </Text>
          </div>

          <div class="mt-10">
            <a href="/contact/">
              <Button>Book a Discovery Meeting</Button>
            </a>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <Section bg="white">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <SectionLabel>Testimonials</SectionLabel>
      <Heading>Trusted to build your website for you</Heading>
    </div>
    <Reviews layout="carousel" count={3} />
  </Section>

  <CTAAboveFooter />
</Layout>
