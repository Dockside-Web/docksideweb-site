---
import Layout from "../layouts/Layout.astro";
import Heading from "../components/ui/Heading.astro";
import Section from "../components/ui/Section.astro";
import ContactForm from "../components/ContactForm.astro";
import HeroSecondary from "../components/HeroSecondary.astro";
import SectionLabel from "../components/ui/SectionLabel.astro";

const faqs = [
  {
    question: "How long does the process take from start to finish?",
    answer:
      "Typical turnaround time is 2 to 3 weeks for a full website, or about 1 week for a landing page. This starts once payment is made and I have everything needed to begin, including your content and branding materials. Delays in approvals or missing content can extend the timeline, and I’ll keep you posted from start to finish."
  },
  {
    question:
      "Will my website be optimized for mobile devices and fast loading speeds?",
    answer:
      "Absolutely. Every site I build is designed to be mobile-responsive so it looks great on any screen, and the static architecture is specifically chosen to ensure top-tier loading speeds."
  },
  {
    question:
      "Are there any hidden costs like hosting, SSL certificates, or domain renewals?",
    answer:
      "There are no hidden surprises! Hosting and your SSL certificate are included in your monthly fee. The only separate cost is your domain name, which you purchase and renew yourself so you keep full ownership and full control of your brand. That means your website address always stays in your name, with no risk of losing access if you ever decide to make changes in the future. Most domains are only around $11 per year."
  },
  {
    question: "Do you use WordPress, Wix, or other site builders?",
    answer:
      "No, I don't use those. I specialize in building custom static sites using HTML, CSS, and JavaScript. This means no clunky database or slow site builders getting in the way, ensuring I have complete control over the performance and design of your site."
  },
  {
    question: "Is basic SEO included in the initial website build?",
    answer:
      "Yes, basic Search Engine Optimization is a core deliverable. I make sure the foundational elements are in place from the start so your site is ready for the web."
  }
];

const pageTitle = "Contact";
const metaDescription =
  "Have a question about your next web project? Contact Dockside Web Solutions today. Use our contact form to get a quote or schedule a discovery call.";
---

<Layout title={pageTitle} description={metaDescription}>
  <HeroSecondary
    label="Talk With Our Team"
    heading="Contact Us"
    description="Tell us a bit about your project. We’ll follow up with next steps!"
  />

  <Section bg="light">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
      <ContactForm />

      <div>
        <SectionLabel>Common Questions</SectionLabel>
        <Heading> Frequently Asked Questions </Heading>

        <div class="mt-8">
          <div class="divide-y divide-navy/10">
            {
              faqs.map((item, i) => (
                <div class="faq-item border-b border-navy/10">
                  <button
                    class="faq-question flex justify-between items-center w-full py-4 text-left text-base font-semibold text-navy hover:text-teal transition-colors duration-200 gap-4 cursor-pointer bg-transparent border-none"
                    aria-expanded="false"
                    aria-controls={`faq-answer-${i}`}
                    id={`faq-btn-${i}`}
                  >
                    <span>{item.question}</span>
                    <span class="faq-chevron shrink-0 text-teal transition-transform duration-300">
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 20 20"
                        fill="none"
                      >
                        <path
                          d="M5 7.5L10 12.5L15 7.5"
                          stroke="currentColor"
                          stroke-width="1.75"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </span>
                  </button>

                  <div
                    class="overflow-hidden max-h-0 transition-[max-height] duration-300 ease-in-out"
                    id={`faq-answer-${i}`}
                    role="region"
                    aria-labelledby={`faq-btn-${i}`}
                  >
                    <p class="pb-4 text-navy text-sm leading-7">
                      {item.answer}
                    </p>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </Section>
</Layout>

<script>
  const questions =
    document.querySelectorAll<HTMLButtonElement>(".faq-question");

  questions.forEach((btn) => {
    btn.addEventListener("click", () => {
      const isOpen = btn.getAttribute("aria-expanded") === "true";
      const answer = document.getElementById(
        btn.getAttribute("aria-controls")!
      ) as HTMLElement;
      const chevron = btn.querySelector<HTMLElement>(".faq-chevron")!;

      // Close all others
      questions.forEach((other) => {
        if (other !== btn) {
          other.setAttribute("aria-expanded", "false");
          const otherAnswer = document.getElementById(
            other.getAttribute("aria-controls")!
          ) as HTMLElement;
          otherAnswer.style.maxHeight = "0px";
          other
            .querySelector<HTMLElement>(".faq-chevron")!
            .classList.remove("rotate-180");
        }
      });

      // Toggle current
      if (isOpen) {
        answer.style.maxHeight = "0px";
        btn.setAttribute("aria-expanded", "false");
        chevron.classList.remove("rotate-180");
      } else {
        answer.style.maxHeight = answer.scrollHeight + "px";
        btn.setAttribute("aria-expanded", "true");
        chevron.classList.add("rotate-180");
      }
    });
  });
</script>
