---
import Layout from "../layouts/Layout.astro";
import Section from "../components/ui/Section.astro";
import Heading from "../components/ui/Heading.astro";
import PricingPlans from "../components/PricingPlans.astro";
import Button from "../components/ui/Button.astro";
import FAQ from "../components/FAQ.astro";
import CTAAboveFooter from "../components/CTAAboveFooter.astro";
import HeroSecondary from "../components/HeroSecondary.astro";

const pageTitle = "Pricing";
const metaDescription =
  "Transparent pricing for premium web development. Explore our subscription-based models and custom project rates designed to fit your business goals.";
---

<Layout title={pageTitle} description={metaDescription}>
  <HeroSecondary
    label="Pricing"
    heading="Simple, Transparent Pricing"
    description="We offer straightforward pricing that scales with your business needs."
  />

  <Section bg="light">
    <PricingPlans />
  </Section>

  <Section bg="white">
    <div class="text-center max-w-3xl mx-auto">
      <Heading>Pricing FAQs</Heading>
    </div>

    <FAQ selectedCategories={["Pricing & Payments"]} />

    <div class="text-center">
      <a href="/faq/">
        <Button variant="secondary" size="md"> View Full FAQ </Button>
      </a>
    </div>
  </Section>

  <CTAAboveFooter />
</Layout>
