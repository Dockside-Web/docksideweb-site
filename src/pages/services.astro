---
import Layout from "../layouts/Layout.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Section from "../components/ui/Section.astro";
import SectionLabel from "../components/ui/SectionLabel.astro";
import CTAAboveFooter from "../components/ui/CTAAboveFooter.astro";
import { Check } from "lucide-astro";

interface ServiceFeature {
  title: string;
  description: string;
  features: string[];
  image: string;
}

const services: ServiceFeature[] = [
  {
    title: "Custom Website Development",
    description:
      "A professionally designed website built specifically for your business.",
    features: [
      "Flawless on Mobile, Tablet, and Desktop",
      "Clean, Easy-to-Use Layout",
      "Fast, Reliable Performance",
      "Designed to Turn Visitors into Customers",
    ],
    image:
      "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80",
  },
  {
    title: "Performance & SEO",
    description:
      "Optimized for speed, visibility, and long-term growth so customers can find you and trust you.",
    features: [
      "Built for Higher Google Rankings",
      "Blazing Fast Load Speeds",
      "Search-Engine Friendly Structure",
      "Clear Visitor Insights & Analytics",
    ],
    image:
      "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80",
  },
  {
    title: "Maintenance & Support",
    description:
      "Ongoing care to keep your website secure, updated, and performing at its best.",
    features: [
      "Proactive Security Updates",
      "Content Changes On Request",
      "Fast Issue Resolution",
      "Continuous Performance Monitoring",
    ],
    image:
      "https://images.unsplash.com/photo-1460925895917-afdab827c52f?auto=format&fit=crop&w=800&q=80",
  },
];
---

<Layout>
  <Section bg="navy" class="text-center">
    <div
      class="absolute inset-0 opacity-12 bg-[url('https://www.transparenttextures.com/patterns/white-wave.png')]"
    >
    </div>
    <SectionLabel>Our Services</SectionLabel>
    <Heading as="h1" class="text-white mb-6">
      Full-Service Web Solutions
    </Heading>
    <Text class="text-slate-300 mb-10">
      From design to deployment to ongoing support, we handle every aspect of
      your online presence. No outsourcing, no templates—just precision
      hand-coded websites built for performance.
    </Text>
    <!-- Wave Divider -->
    <div class="absolute bottom-0 left-0 w-full overflow-hidden leading-[0]">
      <svg
        class="relative block w-full h-24"
        viewBox="0 0 1440 320"
        preserveAspectRatio="none"
      >
        <path
          fill="#FFFFFF"
          d="M0,160L48,176C96,192,192,224,288,213.3C384,203,480,149,576,149.3C672,149,768,203,864,218.7C960,235,1056,213,1152,186.7C1248,160,1344,128,1392,112L1440,96L1440,320L1392,320C1344,320,1248,320,1152,320C1056,320,960,320,864,320C768,320,672,320,576,320C480,320,384,320,288,320C192,320,96,320,48,320L0,320Z"
        ></path>
      </svg>
    </div>
  </Section>

  <Section>
    <div class="space-y-24">
      {
        services.map((service, index) => (
          <div
            class={`flex flex-col ${index % 2 === 1 ? "lg:flex-row-reverse" : "lg:flex-row"} gap-12 items-center`}
          >
            <div class="flex-1">
              <h2 class="text-3xl font-bold text-navy mb-4">{service.title}</h2>
              <p class="text-lg text-slate-600 mb-6 leading-relaxed">
                {service.description}
              </p>

              <div class="bg-slate-50 p-6 rounded-lg border border-slate-100">
                <h4 class="font-bold text-navy mb-4 text-sm uppercase tracking-wide">
                  What's Included:
                </h4>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                  {service.features.map((feature, i) => (
                    <div class="flex items-center space-x-2">
                      <Check class="h-4 w-4 text-gold" />
                      <span class="text-slate-700 text-sm">{feature}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>

            <div class="flex-1 w-full">
              <div class="aspect-video bg-slate-100 rounded-lg shadow-lg overflow-hidden relative group">
                <div class="absolute inset-0 bg-navy/5 group-hover:bg-transparent transition-colors duration-500 z-10" />

                <img
                  src={service.image}
                  alt={service.title}
                  class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Section>

  <Section bg="light">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <SectionLabel>Why Small Businesses Choose Dockside</SectionLabel>
      <Heading>Everything Your Small Business Needs Online</Heading>
      <Text class="mt-4">
        We're not a faceless agency. When you call, you get the owner and
        developer directly. No project managers, no account reps—just honest
        communication and quality work.
      </Text>
    </div>

    <div class="grid md:grid-cols-3 gap-8">
      <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200">
        <div class="text-4xl font-bold text-gold mb-2">2-4</div>
        <div
          class="text-sm font-semibold text-navy uppercase tracking-wide mb-2"
        >
          Weeks
        </div>
        <p class="text-slate-600">
          From kickoff to launch, we move fast without cutting corners.
        </p>
      </div>

      <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200">
        <div class="text-4xl font-bold text-gold mb-2">98+</div>
        <div
          class="text-sm font-semibold text-navy uppercase tracking-wide mb-2"
        >
          PageSpeed
        </div>
        <p class="text-slate-600">
          Every site we build scores 98+ on Google's performance metrics.
        </p>
      </div>

      <div class="bg-white p-8 rounded-xl shadow-sm border border-slate-200">
        <div class="text-4xl font-bold text-gold mb-2">100%</div>
        <div
          class="text-sm font-semibold text-navy uppercase tracking-wide mb-2"
        >
          Hand-Coded
        </div>
        <p class="text-slate-600">
          No templates, no WordPress, no bloated page builders.
        </p>
      </div>
    </div>
  </Section>
</Layout>

<CTAAboveFooter />
