---
import { ArrowRight } from "lucide-astro";

const processSteps = [
  {
    title: "Discovery",
    desc: "We clarify your goals and budget so every page supports your business objectives.",
  },
  {
    title: "Design & Build",
    desc: "We craft a modern, mobile‑first website tailored to your brand, optimized for speed and SEO.",
  },
  {
    title: "Launch",
    desc: "We handle testing and deployment, so your new site goes live smoothly and reliably.",
  },
  {
    title: "Support",
    desc: "We provide ongoing updates and performance checks to keep your site working hard for you.",
  },
];
---

<div class="grid grid-cols-1 md:grid-cols-4 gap-8 relative z-10">
      {
        processSteps.map((step, i) => (
          <div class="relative">
            <div class="bg-navy-light p-8 rounded-lg border border-white/10 hover:border-gold/50 transition-colors duration-300 h-full group hover:bg-navy-light/80">
              <span class="text-6xl font-bold text-white/5 absolute top-4 right-4 group-hover:text-gold/10 transition-colors">
                {i + 1}
              </span>
              <h3 class="text-xl font-bold text-white mb-4 relative z-10 group-hover:text-gold transition-colors">
                {step.title}
              </h3>
              <p class="text-slate-400 text-sm relative z-10">{step.desc}</p>
            </div>
            {i < 3 && (
              <div class="hidden md:block absolute top-1/2 -right-4 transform -translate-y-1/2 z-20">
                <ArrowRight class="text-gold h-6 w-6" />
              </div>
            )}
          </div>
        ))
      }
    </div>