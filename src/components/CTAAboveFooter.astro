---
import Section from "./ui/Section.astro";
import Heading from "./ui/Heading.astro";
import Button from "./ui/Button.astro";
import { getImage } from "astro:assets";
import ropeImage from "../assets/rope-border2.png";

const optimizedRope = await getImage({ src: ropeImage });
---

<Section bg="light" pad={false}>
  <section class="flex items-center justify-center px-4 sm:px-8">
    <div
      class="relative w-full max-w-3xl flex flex-col items-center justify-center text-center
             min-h-[240px] sm:min-h-[260px]
             bg-no-repeat bg-center bg-contain
             md:bg-size-[100%_100%]"
      style={`background-image: url(${optimizedRope.src});`}
    >
      <div
        class="z-10 flex flex-col items-center max-w-sm px-5 sm:px-6 py-6 sm:py-8"
      >
        <Heading class="mb-4 sm:mb-6">Choose me!!!</Heading>
        <p class="text-base sm:text-xl mb-6 sm:mb-10 font-medium">
          Please choose me to be your partner in success.
        </p>
        <a href="/contact">
          <Button
            variant="primary"
            withArrow
            class="text-sm px-4 py-2 sm:text-base sm:px-6 sm:py-3"
          >
            Get Started Today
          </Button>
        </a>
      </div>
    </div>
  </section>
</Section>
