---
import { Image } from 'astro:assets';
import CTABackgroundImage from '../assets/CTABackgroundImage.webp';
import Button from './ui/Button.astro';
---

<section class="relative min-h-115 flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <Image
    src={CTABackgroundImage}
    alt="Ocean scene with yachts at marina"
    class="absolute inset-0 w-full h-full object-cover"
    loading="lazy"
    decoding="async"
  />
  <!-- Subtle overlay to ensure text legibility -->
  <div class="absolute inset-0 bg-white/10"></div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center gap-8 px-6 text-center">
    <h2 class="text-4xl md:text-5xl text-navy tracking-wide">
      Ready to make some waves?
    </h2>
    <a
      href="/contact/"
      class="inline-block"
    >
      <Button variant="secondary" size="lg">Get On Board</Button>
    </a>
  </div>
</section>