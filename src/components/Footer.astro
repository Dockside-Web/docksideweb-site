---
import Logo from "../assets/logo/logo-horizontal-light.svg";
import Button from "./ui/Button.astro";
import { Mail, Phone, MapPin } from "lucide-astro";

const currentYear = new Date().getFullYear();

const navigationLinks = ["Home", "Pricing", "Web-Design", "SEO", "Contact", "FAQ", "Portfolio", "About"];
---

<div class="w-full">
  <footer class="relative bg-linear-to-b bg-navy text-white pb-8 -mt-1">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12">

        <!-- Logo / CTA -->
        <div class="space-y-4 flex flex-col items-center md:items-start">
          <Logo class="h-25 w-auto" aria-label="Dockside Web Solutions Logo" />
          <p class="text-slate-400 text-sm leading-relaxed">
            Fast, modern websites for small businesses
          </p>
          <a href="/contact/" class="flex items-center space-x-2">
            <Button variant="primary" size="sm">Get Started Today</Button>
          </a>
        </div>

        <!-- Navigation -->
        <div class="flex flex-col items-center">
          <div>
            <h3 class="text-gold font-bold uppercase tracking-wider text-sm mb-6">
              Quick Links
            </h3>
            <ul class="grid grid-cols-2 gap-x-8 gap-y-3 w-fit">
              {
                navigationLinks.map((item) => (
                  <li>
                    <a
                      href={item === "Home" ? "/" : `/${item.toLowerCase()}/`}
                      class="text-slate-300 hover:text-teal transition-colors text-sm"
                    >
                      {item}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>

        <!-- Contact -->
        <div class="flex flex-col items-center md:items-start">
          <div>
            <h3 class="text-gold font-bold uppercase tracking-wider text-sm mb-6">
              Contact
            </h3>
            <ul class="space-y-4">
              <li class="flex items-start space-x-3 text-slate-300 text-sm">
                <Mail class="h-5 w-5 text-teal shrink-0" />
                <a href="mailto:contact@docksideweb.com" class="hover:text-teal">
                  contact@docksideweb.com
                </a>
              </li>
              <li class="flex items-start space-x-3 text-slate-300 text-sm">
                <Phone class="h-5 w-5 text-teal shrink-0" />
                <a href="tel:+14438447850" class="hover:text-teal">
                  +1 (443) 844-7850
                </a>
              </li>
              <li class="flex items-start space-x-3 text-slate-300 text-sm">
                <MapPin class="h-5 w-5 text-teal shrink-0" />
                <span>Baltimore, MD</span>
              </li>
              <li class="flex items-start space-x-3 text-slate-300 text-sm">
                <MapPin class="h-5 w-5 text-teal shrink-0" />
                <span>Charleston, SC</span>
              </li>
            </ul>
          </div>
        </div>

      </div>

      <div class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center">
        <p class="text-slate-500 text-sm">
          © {currentYear} Dockside Web Solutions. All rights reserved.
        </p>
        <div class="flex space-x-3 mt-4 md:mt-0">
          <a
            href="/legal/privacy-policy/"
            class="text-slate-400 hover:text-yellow-500 transition-colors text-sm"
            aria-label="Privacy Policy"
          >
            <p>Privacy Policy</p>
          </a>
          <p class="text-slate-400">|</p>
          <a
            href="/legal/terms-of-service/"
            class="text-slate-400 hover:text-yellow-500 transition-colors text-sm"
            aria-label="Terms of Service"
          >
            <p>Terms of Service</p>
          </a>
        </div>
      </div>
    </div>
  </footer>
</div>